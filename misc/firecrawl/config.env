# firecrawl
REDIS_URL="redis://firecrawl-redis:6379"
REDIS_RATE_LIMIT_URL="redis://firecrawl-redis:6379"
PLAYWRIGHT_MICROSERVICE_URL="http://firecrawl-playwright:3000/scrape"
POSTGRES_USER="postgres" # hardcoded: it's what firecrawl-api expects
POSTGRES_PASSWORD="postgres" # hardcoded: it's what firecrawl-api expects
POSTGRES_DB="postgres" # hardcoded: it's what firecrawl-api expects
POSTGRES_HOST="firecrawl-postgres"
POSTGRES_PORT="5432"
USE_DB_AUTHENTICATION="false"
NUM_WORKERS_PER_QUEUE="8"
CRAWL_CONCURRENT_REQUESTS="10"
MAX_CONCURRENT_JOBS="5"
BROWSER_POOL_SIZE="5"
OPENAI_API_KEY="${FIRECRAWL_OPENAI_API_KEY}"
OPENAI_BASE_URL="https://api.openai.com/v1"
MODEL_NAME="gpt-5.4-nano"
MODEL_EMBEDDING_NAME="text-embedding-3-large"
SEARXNG_ENDPOINT="http://searxng-core:8080"

# playwright
ALLOW_LOCAL_WEBHOOKS="true"
BLOCK_MEDIA="true"
MAX_CONCURRENT_PAGES="10"

# common
HOST="0.0.0.0"
EXTRACT_WORKER_PORT="3004"
WORKER_PORT="3005"
NUQ_RABBITMQ_URL="amqp://firecrawl-rabbitmq:5672"
HARNESS_STARTUP_TIMEOUT_MS="60000"
ENV="local"